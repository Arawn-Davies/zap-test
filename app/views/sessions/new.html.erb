<% content_for :title, "Login" %>

<div class="flex justify-center mt-8">
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 w-full max-w-md">
    <h1 class="text-3xl font-bold text-indigo-700 mb-6 text-center">Sign In</h1>

    <%= form_with url: login_path, class: "space-y-5" do |f| %>
      <div>
        <%= f.label :username, "Username or Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :username, autocomplete: "username",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      </div>
      <div>
        <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      </div>
      <%= f.submit "Sign In",
          class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg transition cursor-pointer" %>
    <% end %>
  </div>
</div>
