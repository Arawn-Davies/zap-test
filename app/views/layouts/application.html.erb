<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Hello World Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="bg-indigo-700 shadow-lg">
      <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="<%= root_path %>" class="text-white text-2xl font-bold tracking-tight hover:text-indigo-200 transition">
          ✍️ Hello World Blog
        </a>
        <div class="flex items-center gap-4">
          <a href="<%= root_path %>" class="text-indigo-100 hover:text-white transition font-medium">Home</a>
          <% if logged_in? %>
            <a href="<%= admin_root_path %>" class="text-indigo-100 hover:text-white transition font-medium">Admin</a>
            <%= button_to "Logout", logout_path, method: :delete,
                class: "bg-indigo-500 hover:bg-indigo-400 text-white px-3 py-1 rounded-lg text-sm font-medium transition" %>
          <% else %>
            <a href="<%= login_path %>" class="bg-white text-indigo-700 hover:bg-indigo-50 px-3 py-1 rounded-lg text-sm font-medium transition">
              Login
            </a>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if flash[:notice] %>
      <div class="bg-green-100 border border-green-400 text-green-800 px-4 py-3 text-center text-sm" role="alert">
        <%= flash[:notice] %>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="bg-red-100 border border-red-400 text-red-800 px-4 py-3 text-center text-sm" role="alert">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Main content -->
    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-indigo-700 text-indigo-200 text-center py-4 text-sm">
      &copy; <%= Time.current.year %> Hello World Blog — Built with Ruby on Rails &amp; Tailwind CSS
    </footer>
  </body>
</html>
