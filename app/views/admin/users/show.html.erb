<% content_for :title, @user.username %>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
  <header class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-4xl font-bold text-gray-800 mb-2"><%= @user.username %></h1>
      <div class="text-sm text-gray-400">
        Member since <%= @user.created_at.strftime("%B %-d, %Y") %>
      </div>
    </div>
    <% if @user.admin? %>
      <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-sm font-medium">Admin</span>
    <% else %>
      <span class="bg-gray-100 text-gray-600 px-3 py-1 rounded-full text-sm font-medium">User</span>
    <% end %>
  </header>

  <dl class="grid grid-cols-1 gap-4 text-sm">
    <div class="bg-gray-50 rounded-xl px-5 py-4">
      <dt class="text-gray-400 font-medium mb-1">Email</dt>
      <dd class="text-gray-800"><%= @user.email %></dd>
    </div>
    <div class="bg-gray-50 rounded-xl px-5 py-4">
      <dt class="text-gray-400 font-medium mb-1">Username</dt>
      <dd class="text-gray-800"><%= @user.username %></dd>
    </div>
    <div class="bg-gray-50 rounded-xl px-5 py-4">
      <dt class="text-gray-400 font-medium mb-1">Posts</dt>
      <dd class="text-gray-800"><%= @user.posts.count %></dd>
    </div>
  </dl>
</div>

<div class="mt-6 flex gap-4">
  <%= link_to "Edit", edit_admin_user_path(@user),
      class: "bg-indigo-600 text-white px-4 py-2 rounded-xl font-medium hover:bg-indigo-700 transition text-sm" %>
  <%= link_to "Delete", admin_user_path(@user),
      data: { turbo_method: :delete, turbo_confirm: "Delete #{@user.username}? This cannot be undone." },
      class: "bg-red-50 text-red-600 px-4 py-2 rounded-xl font-medium hover:bg-red-100 transition text-sm" %>
  <%= link_to "← Back to users", admin_users_path,
      class: "text-indigo-600 font-medium hover:text-indigo-800 transition text-sm self-center" %>
</div>
