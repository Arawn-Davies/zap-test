<%= form_with model: [:admin, @user], class: "space-y-5" do |f| %>

  <% if @user.errors.any? %>
    <div class="bg-red-50 border border-red-100 rounded-xl px-5 py-4 text-sm text-red-600">
      <p class="font-medium mb-1"><%= pluralize(@user.errors.count, "error") %> prevented this user from being saved:</p>
      <ul class="list-disc list-inside space-y-1">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :username, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :username,
        class: "w-full border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.email_field :email,
        class: "w-full border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.password_field :password,
        placeholder: @user.persisted? ? "Leave blank to keep current password" : "",
        class: "w-full border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.password_field :password_confirmation,
        placeholder: @user.persisted? ? "Leave blank to keep current password" : "",
        class: "w-full border border-gray-200 rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.check_box :admin, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-300" %>
    <%= f.label :admin, "Admin user", class: "text-sm font-medium text-gray-700" %>
  </div>

  <%= f.submit class: "bg-indigo-600 text-white px-5 py-2 rounded-xl font-medium hover:bg-indigo-700 transition text-sm cursor-pointer" %>

<% end %>
