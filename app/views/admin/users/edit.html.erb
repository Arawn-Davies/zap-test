<% content_for :title, "Edit #{@user.username}" %>

<div class="mb-8">
  <h1 class="text-4xl font-bold text-indigo-700 mb-2">Edit <%= @user.username %></h1>
  <p class="text-gray-500 text-lg">Update this user's account details.</p>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
  <%= render "form" %>
</div>

<div class="mt-6 flex gap-4">
  <%= link_to "← Back to users", admin_users_path,
      class: "text-indigo-600 font-medium hover:text-indigo-800 transition text-sm" %>
  <%= link_to "View user", admin_user_path(@user),
      class: "text-indigo-600 font-medium hover:text-indigo-800 transition text-sm" %>
</div>
