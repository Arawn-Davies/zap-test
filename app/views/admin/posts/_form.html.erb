<%= form_with model: [:admin, post], class: "space-y-6" do |f| %>
  <% if post.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <ul class="list-disc list-inside text-red-700 text-sm space-y-1">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title,
        class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :body, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :body, rows: 12,
        class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :published_at, "Publish Date (leave blank to save as draft)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.datetime_local_field :published_at,
        class: "border border-gray-300 rounded-lg px-3 py-2 text-gray-800 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded-lg transition cursor-pointer" %>
    <%= link_to "Cancel", admin_posts_path, class: "text-gray-500 hover:text-gray-700 font-medium py-2 px-4 transition" %>
  </div>
<% end %>
