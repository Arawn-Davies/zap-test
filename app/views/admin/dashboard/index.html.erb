<% content_for :title, "Admin Dashboard" %>

<div class="mb-8">
  <h1 class="text-4xl font-bold text-indigo-700 mb-2">Admin Dashboard</h1>
  <p class="text-gray-500 text-lg">Manage your blog.</p>
</div>

<div class="grid grid-cols-2 gap-6">
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-xl font-semibold text-gray-800 mb-1">Posts</h2>
    <p class="text-gray-400 text-sm mb-4"><%= Post.count %> total</p>
    <%= link_to "Manage Posts", admin_posts_path,
                class: "text-indigo-600 font-medium hover:text-indigo-800 transition text-sm" %>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-xl font-semibold text-gray-800 mb-1">Users</h2>
    <p class="text-gray-400 text-sm mb-4"><%= User.count %> total</p>
    <%= link_to "Manage Users", admin_users_path,
                class: "text-indigo-600 font-medium hover:text-indigo-800 transition text-sm" %>
  </div>
</div>