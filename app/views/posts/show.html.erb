<% content_for :title, @post.title %>

<article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
  <header class="mb-6">
    <h1 class="text-4xl font-bold text-gray-800 mb-3"><%= @post.title %></h1>
    <div class="text-sm text-gray-400">
      Published <%= @post.published_at.strftime("%B %-d, %Y") %>
      by <span class="font-medium text-gray-600"><%= @post.user.username %></span>
    </div>
  </header>
  <div class="prose prose-indigo max-w-none text-gray-700 leading-relaxed whitespace-pre-wrap">
    <%= @post.body %>
  </div>
</article>

<div class="mt-6">
  <%= link_to "← Back to all posts", root_path,
      class: "text-indigo-600 font-medium hover:text-indigo-800 transition text-sm" %>
</div>
