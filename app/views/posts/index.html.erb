<% content_for :title, "Hello World Blog" %>

<div class="mb-8">
  <h1 class="text-4xl font-bold text-indigo-700 mb-2">Welcome to Hello World Blog</h1>
  <p class="text-gray-500 text-lg">Thoughts, ideas, and stories.</p>
</div>

<% if @posts.any? %>
  <div class="grid gap-6">
    <% @posts.each do |post| %>
      <article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition">
        <h2 class="text-2xl font-semibold text-gray-800 mb-2">
          <%= link_to post.title, post_path(post), class: "hover:text-indigo-600 transition" %>
        </h2>
        <div class="text-sm text-gray-400 mb-3">
          Published <%= post.published_at.strftime("%B %-d, %Y") %>
          by <span class="font-medium text-gray-600"><%= post.user.username %></span>
        </div>
        <p class="text-gray-600 leading-relaxed">
          <%= truncate(post.body, length: 200) %>
        </p>
        <div class="mt-4">
          <%= link_to "Read more →", post_path(post),
              class: "text-indigo-600 font-medium hover:text-indigo-800 transition text-sm" %>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center text-gray-400">
    <p class="text-xl mb-2">No posts yet.</p>
    <p class="text-sm">Check back soon!</p>
  </div>
<% end %>
